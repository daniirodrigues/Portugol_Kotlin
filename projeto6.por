programa {
  funcao inicio() {
    
    inteiro numero = 0
    escreva("Informe um número: ")
    leia (numero)

    se (numero > 0) {
      escreva ("Numero é Positivo!")
    }
    se (numero < 0) {
      escreva ("Numero é Negativo")
    }
    se (numero == 0) {
      escreva ("Numero é Zero!")
    }


  }
}
